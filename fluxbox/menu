[begin] (FluxBox)
    [submenu] (Development)
        [exec] (IDLE [Python IDE]) {idle}
        [exec] (Python) {xterm -e python}
    [end]
    [submenu] (Editors)
        [exec] (Nano) {xterm -e nano}
        [exec] (Neovim) {xterm -e nvim}
        [exec] (Vim) {xterm -e vim}
    [end]
    [submenu] (Games)
        [submenu] (Adventure)
            [exec] (Sclient) {sclient}
        [end]
        [submenu] (Arcade)
            [exec] (PacMan) {pacman}
        [end]
    [end]
    [submenu] (Multimedia)
        [exec] (Qt V4L2 test Utility) {qv4l2}
        [exec] (Qt V4L2 video capture utility) {qvidcap}
    [end]
    [submenu] (Network)
        [exec] (Avahi SSH Server Browser) {bssh}
        [exec] (Avahi VNC Server Browser) {bvnc}
        [exec] (FireFox) {firefox}
        [exec] (TkVNC) {xterm -e tkvnc}
    [end]
    [submenu] (Shells)
        [exec] (Alacritty) {alacritty}
        [exec] (File Manager PCManFM) {pcmanfm}
        [exec] (GIT) {xterm -e git}
        [exec] (UXTerm) {uxterm}
        [exec] (Xterm) {xterm}
    [end]
    [submenu] (System)
        [submenu] (Settings)
            [submenu] (GNOME)
                [exec] (Advanced Network Configuration) {nm-connection-editor}
            [end]
            [exec] (Desktop Preferences) {pcmanfm --desktop-pref}
            [exec] (Fcitx 5 Configuration) {fcitx5-configtool}
            [exec] (Fcitx 5 Migration Wizard) {fcitx5-migrator}
            [exec] (Openbox Configuration Manager) {obconf}
            [exec] (Preferred Applications) {libfm-pref-apps}
            [exec] (Tint2 Settings) {tint2conf}
        [end]
        [exec] (Avahi Zeroconf Browser) {avahi-discover}
        [exec] (Fcitx 5) {fcitx5}
        [exec] (Htop) {xterm -e htop}
        [exec] (pstree) {xterm -e pstree.x11}
        [exec] (pstree) {xterm -e pstree}
        [exec] (pstree) {xterm -e /usr/bin/pstree.x11}
        [exec] (Tint2) {tint2}
        [exec] (Top) {xterm -e top}
    [end]
    [submenu] (Utilities)
        [exec] (Info) {xterm -e info}
        [exec] (Keyboard layout viewer) {kbd-layout-viewer5}
    [end]
    [separator]
    [submenu] (FluxBox)
        [workspaces] (Workspaces)
        [submenu] (Styles)
            [stylesdir] (~/.fluxbox/styles)
        [end]
        [config] (Configure)
        [reconfig] (Reconfig)
        [restart] (Restart)
        [separator]
        [exit] (Exit)
    [end]
[end]
